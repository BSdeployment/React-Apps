{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Md Editor",
  "version": "0.1.0",
  "identifier": "com.mdeditor.app",
  "build": {
    "frontendDist": "webview",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
     "devUrl": "http://localhost:5174"
  },
  "app": {
    "windows": [
      {
        "title": "Md Editor",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
